<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="theme-color" content="#FFFFFF" />
  <title>Pest Repeller — Ultratovushli zararkunanda qaytargich | Savdomix</title>
  <meta name="description" content="Rozetkaga ulanadigan Pest Repeller ultratovushli qurilma. Sprey va zahar kerak emas. O'zbekiston bo'ylab yetkazib berish, oldindan to'lov yo'q. 125 000 so'm." />

  <link rel="canonical" href="https://repeller.savdomix.uz/" />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="product" />
  <meta property="og:locale" content="uz_UZ" />
  <meta property="og:title" content="Pest Repeller — Ultratovushli zararkunanda qaytargich" />
  <meta property="og:description" content="Rozetkaga ulang. Sprey va zahar kerak emas. To'lov mahsulotni olganda — 125 000 so'm." />
  <meta property="og:url" content="https://repeller.savdomix.uz/" />
  <meta property="og:image" content="https://repeller.savdomix.uz/assets/og.jpg" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Preload critical assets -->
  <link rel="preload" as="style" href="/assets/styles.css" />
  <link rel="preload" as="image" href="/assets/product-master.png" />
  <link rel="stylesheet" href="/assets/styles.css" />

  <!-- Structured data: Product + Offer -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": "Pest Repeller Ultratovushli zararkunanda qaytargich",
    "brand": { "@type": "Brand", "name": "Savdomix" },
    "description": "Rozetkaga ulanadigan ultratovushli qurilma uy va idora uchun. Sprey va kimyoviy vositalar talab qilmaydi.",
    "image": "https://repeller.savdomix.uz/assets/og.jpg",
    "offers": {
      "@type": "Offer",
      "url": "https://repeller.savdomix.uz/",
      "priceCurrency": "UZS",
      "price": "125000",
      "availability": "https://schema.org/InStock",
      "areaServed": "UZ",
      "acceptedPaymentMethod": "http://purl.org/goodrelations/v1#Cash"
    }
  }
  </script>

  <!-- Meta Pixel base -->
  <script>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
    n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
