/* Savdomix — Pest Repeller Landing Page
   Premium mobile-first design. No frameworks. System font stack.
   Redesigned: real product image, lifestyle photos, improved conversion architecture. */

:root {
  /* Colors */
  --c-base:      #F7F8FA;
  --c-surface:   #FFFFFF;
  --c-surface-2: #F1F4F8;
  --c-ink:       #0B1220;
  --c-muted:     #4B5565;
  --c-accent:    #2563EB;
  --c-accent-2:  #4F46E5;
  --c-accent-hover: #1D4ED8;
  --c-danger:    #DC2626;
  --c-success:   #16A34A;
  --c-hairline:  #E2E8F0;
  --c-ring:      #93C5FD;
  --c-badge-bg:  #EFF6FF;
  --c-badge-ink: #1E40AF;
  --c-green-bg:  #DCFCE7;
  --c-green-ink: #166534;

  /* Gradient */
  --grad-btn: linear-gradient(135deg, var(--c-accent) 0%, var(--c-accent-2) 100%);
  --grad-hero: linear-gradient(160deg, #FFFFFF 0%, #EFF6FF 60%, #F0F4FF 100%);

  /* Typography */
  --ff-sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
             "Segoe UI", Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
  --fw-regular: 450;
  --fw-medium:  560;
  --fw-semibold: 650;
  --fw-bold:    720;

  /* Spacing */
  --s-4:4px; --s-8:8px; --s-12:12px; --s-16:16px;
  --s-24:24px; --s-32:32px; --s-48:48px; --s-64:64px; --s-96:96px;

  /* Radii */
  --r-sm:10px; --r-md:16px; --r-lg:20px; --r-xl:24px; --r-2xl:32px;

  /* Shadows */
  --sh-sm:  0 1px 3px rgba(11,18,32,.07), 0 1px 2px rgba(11,18,32,.05);
  --sh-md:  0 8px 24px rgba(11,18,32,.09), 0 2px 6px rgba(11,18,32,.06);
  --sh-lg:  0 20px 48px rgba(11,18,32,.13), 0 6px 16px rgba(11,18,32,.08);
  --sh-product: 0 24px 64px rgba(37,99,235,.18), 0 8px 24px rgba(37,99,235,.10);

  /* Motion */
  --ease-out: cubic-bezier(.22,1,.36,1);
  --dur-1: 140ms; --dur-2: 220ms; --dur-3: 420ms;
}

/* ===== RESET ===== */
*, *::before, *::after { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
body {
  font-family: var(--ff-sans);
  color: var(--c-ink);
  background: var(--c-base);
  font-size: 16px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}
img, svg { display: block; max-width: 100%; }
button { font-family: inherit; }
a { color: inherit; }

/* ===== UTILITIES ===== */
.hidden { display: none !important; }
.muted { color: var(--c-muted); }
.small { font-size: 13px; }
.micro { font-size: 12px; color: var(--c-muted); line-height: 1.5; }

.skip { position: absolute; left: -9999px; top: auto; }
.skip:focus { left: 16px; top: 16px; background: var(--c-ink); color: #fff; padding: 8px 12px; border-radius: 8px; z-index: 100; }

/* ===== CONTAINER ===== */
.container { width: 100%; margin: 0 auto; padding: 0 16px; }
@media (min-width: 390px) { .container { padding: 0 18px; } }
@media (min-width: 430px) { .container { padding: 0 20px; } }
@media (min-width: 900px) { .container { max-width: 1120px; padding: 0 24px; } }

/* ===== TOPBAR ===== */
.topbar {
  background: rgba(255,255,255,.92);
  backdrop-filter: saturate(160%) blur(12px);
  -webkit-backdrop-filter: saturate(160%) blur(12px);
  border-bottom: 1px solid var(--c-hairline);
  position: sticky; top: 0; z-index: 40;
}
.topbar__row {
  display: flex; align-items: center; gap: 12px;
  min-height: 54px; padding-top: 8px; padding-bottom: 8px;
  flex-wrap: wrap;
}
.brand {
  display: inline-flex; align-items: center; gap: 8px;
  text-decoration: none; color: var(--c-ink); flex-shrink: 0;
}
.brand__mark { width: 22px; height: 22px; color: var(--c-accent); }
.brand__name { font-weight: var(--fw-bold); font-size: 17px; letter-spacing: -0.01em; }
.trustPills { list-style: none; margin: 0; padding: 0; display: flex; gap: 6px; flex-wrap: wrap; }
.pill {
  display: inline-flex; align-items: center; gap: 4px;
  background: var(--c-badge-bg); color: var(--c-badge-ink);
  border-radius: 999px; padding: 4px 9px;
  font-size: 11px; font-weight: var(--fw-medium); white-space: nowrap;
}
.pill--green { background: var(--c-green-bg); color: var(--c-green-ink); }
.pill span { font-size: 10px; }
@media (min-width: 430px) { .pill { font-size: 12px; padding: 5px 10px; } }
@media (max-width: 359px) { .pill--last { display: none; } }

/* ===== BADGES ===== */
.badge {
  display: inline-flex; align-items: center; gap: 5px;
  border-radius: 999px; padding: 5px 11px;
  font-size: 12px; font-weight: var(--fw-semibold); white-space: nowrap;
}
.badge svg { width: 12px; height: 12px; }
.badge--blue { background: var(--c-badge-bg); color: var(--c-badge-ink); }
.badge--gray { background: var(--c-surface-2); color: var(--c-muted); border: 1px solid var(--c-hairline); }
.badge--green { background: var(--c-green-bg); color: var(--c-green-ink); }

/* ===== TYPOGRAPHY ===== */
.h1 {
  font-size: 32px; line-height: 1.1; letter-spacing: -0.025em;
  font-weight: var(--fw-bold); margin: 0;
}
.h1--accent {
  background: var(--grad-btn);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.h2 { font-size: 24px; line-height: 1.2; letter-spacing: -0.015em; font-weight: var(--fw-semibold); margin: 0; }
.h3 { font-size: 17px; line-height: 1.3; letter-spacing: -0.005em; font-weight: var(--fw-semibold); margin: 0; }
.lead { font-size: 16px; line-height: 1.55; color: var(--c-muted); margin: 6px 0 0; }
.eyebrow {
  font-size: 12px; letter-spacing: .08em; text-transform: uppercase;
  color: var(--c-accent); font-weight: var(--fw-semibold); margin: 0 0 8px;
}
@media (min-width: 900px) {
  .h1 { font-size: 48px; }
  .h2 { font-size: 32px; }
  .h3 { font-size: 20px; }
  .lead { font-size: 18px; }
}

/* ===== HERO ===== */
.hero {
  padding: 20px 0 16px;
  background: var(--grad-hero);
  position: relative; overflow: hidden;
}
.hero__bg {
  position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 60% 40% at 80% 20%, rgba(37,99,235,.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 20% 80%, rgba(79,70,229,.04) 0%, transparent 70%);
}
.hero__grid {
  display: flex; flex-direction: column; gap: 20px;
  position: relative; z-index: 1;
}
.hero__copy { order: 2; }
.hero__visual { order: 1; margin: 0; }
.hero__eyebrow {
  font-size: 12px; letter-spacing: .08em; text-transform: uppercase;
  color: var(--c-accent); font-weight: var(--fw-semibold); margin: 0 0 10px;
}
.hero__sub { color: var(--c-muted); font-size: 16px; margin: 12px 0 0; max-width: 36em; }

@media (min-width: 900px) {
  .hero { padding: 56px 0 40px; }
  .hero__grid { flex-direction: row; align-items: center; gap: 56px; }
  .hero__copy { order: 1; flex: 1; }
  .hero__visual { order: 2; flex: 0 0 420px; }
}

/* Product card with animated waves */
.productCard {
  position: relative;
  display: grid; place-items: center;
  padding: 20px 16px 12px;
}
.productCard__waves {
  position: absolute; inset: 0;
  display: grid; place-items: center;
  pointer-events: none;
}
.wave {
  position: absolute;
  border-radius: 50%;
  border: 1.5px solid rgba(37,99,235,.18);
  animation: waveExpand 3s ease-out infinite;
}
.wave-1 { width: 180px; height: 180px; animation-delay: 0s; }
.wave-2 { width: 260px; height: 260px; animation-delay: 1s; }
.wave-3 { width: 340px; height: 340px; animation-delay: 2s; }
@keyframes waveExpand {
  0%   { transform: scale(.7); opacity: .6; }
  100% { transform: scale(1.2); opacity: 0; }
}
.productCard__img {
  position: relative; z-index: 2;
  width: 100%; max-width: 320px;
  height: auto; aspect-ratio: 1;
  object-fit: contain;
  filter: drop-shadow(var(--sh-product));
  transition: transform var(--dur-3) var(--ease-out);
}
.productCard__img:hover { transform: translateY(-4px) scale(1.02); }
@media (min-width: 900px) { .productCard__img { max-width: 380px; } }

.productBadges {
  display: flex; gap: 8px; flex-wrap: wrap;
  justify-content: center; margin-top: 12px;
}

/* ===== PRICE CARD ===== */
.priceCard {
  margin-top: 20px;
  background: var(--c-surface);
  border: 1.5px solid var(--c-hairline);
  border-radius: var(--r-xl); padding: 14px 16px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 14px; box-shadow: var(--sh-sm);
}
.priceCard__main { display: flex; flex-direction: column; gap: 2px; }
.priceCard__label { font-size: 12px; color: var(--c-muted); }
.price {
  font-size: 28px; font-weight: var(--fw-bold);
  letter-spacing: -0.025em;
  background: var(--grad-btn);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.price small { font-size: 14px; font-weight: var(--fw-medium); color: var(--c-muted); margin-left: 2px; -webkit-text-fill-color: var(--c-muted); }
.priceCard__notes { list-style: none; margin: 0; padding: 0; text-align: right; font-size: 12px; color: var(--c-success); line-height: 1.6; font-weight: var(--fw-medium); }

/* ===== BUTTONS ===== */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 10px;
  font-weight: var(--fw-semibold); border-radius: 14px; height: 48px; padding: 0 18px;
  border: 1px solid transparent; cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  transition:
    background-color var(--dur-2) var(--ease-out),
    box-shadow var(--dur-2) var(--ease-out),
    transform var(--dur-1) var(--ease-out),
    opacity var(--dur-2) var(--ease-out);
  font-size: 16px; line-height: 1; white-space: nowrap;
}
.btn-lg { height: 56px; padding: 0 22px; border-radius: 16px; font-size: 16px; }
.btn:active { transform: translateY(1px); }
.btn:focus-visible { outline: none; box-shadow: 0 0 0 4px rgba(147,197,253,.6); }
.btn:disabled { cursor: not-allowed; opacity: .65; }

.btn-primary {
  background: var(--grad-btn);
  color: #fff;
  box-shadow: 0 4px 14px rgba(37,99,235,.35), 0 1px 3px rgba(37,99,235,.2);
}
.btn-primary:hover {
  box-shadow: 0 6px 20px rgba(37,99,235,.45), 0 2px 6px rgba(37,99,235,.25);
  opacity: .92;
}
.btn-secondary {
  background: var(--c-surface);
  color: var(--c-ink);
  border-color: var(--c-hairline);
  box-shadow: var(--sh-sm);
}
.btn-secondary:hover { background: var(--c-surface-2); }
.btn .i { width: 18px; height: 18px; }

/* ===== HERO CTAs ===== */
.hero__ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }

/* ===== MICRO CALLOUTS ===== */
.microCallouts {
  list-style: none; margin: 18px 0 0; padding: 0;
  display: flex; gap: 14px; flex-wrap: wrap;
  color: var(--c-muted); font-size: 13px;
}
.microCallouts li { display: inline-flex; align-items: center; gap: 6px; }
.i-sm { width: 14px; height: 14px; flex-shrink: 0; }

/* ===== SECTION BASE ===== */
.section { padding: 48px 0; }
.sectionHead { margin-bottom: 28px; max-width: 46em; }
@media (min-width: 900px) { .section { padding: 80px 0; } }

.divider {
  position: relative; height: 1px; border: 0; margin: 0;
  background: var(--c-hairline);
}
.divider::after {
  content: ''; position: absolute; left: 50%; top: 50%;
  width: 6px; height: 6px; border-radius: 999px;
  background: var(--c-accent);
  transform: translate(-50%, -50%);
  box-shadow: 0 0 0 4px rgba(37,99,235,.12);
}

/* ===== STEPS ===== */
.steps { list-style: none; margin: 0; padding: 0; display: grid; gap: 14px; }
.step {
  display: flex; gap: 16px; align-items: flex-start;
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-xl); padding: 18px 16px;
  box-shadow: var(--sh-sm);
  transition: box-shadow var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out);
}
.step:hover { box-shadow: var(--sh-md); transform: translateY(-2px); }
.step__num {
  flex-shrink: 0; width: 36px; height: 36px; border-radius: 999px;
  background: var(--grad-btn); color: #fff;
  display: grid; place-items: center;
  font-weight: var(--fw-bold); font-size: 15px;
  box-shadow: 0 4px 10px rgba(37,99,235,.3);
}
.step p { margin: 6px 0 0; color: var(--c-muted); font-size: 15px; line-height: 1.5; }
@media (min-width: 900px) { .steps { grid-template-columns: repeat(3, 1fr); } }

.note-box {
  display: flex; align-items: flex-start; gap: 8px;
  background: var(--c-surface-2); border: 1px solid var(--c-hairline);
  border-radius: var(--r-md); padding: 12px 14px;
  margin-top: 20px;
}
.note-box .i-sm { margin-top: 1px; flex-shrink: 0; color: var(--c-accent); }

/* ===== ROOM GRID (Where to use) ===== */
.roomGrid {
  display: grid; gap: 16px;
  grid-template-columns: 1fr;
}
@media (min-width: 600px) { .roomGrid { grid-template-columns: 1fr 1fr; } }
@media (min-width: 900px) { .roomGrid { grid-template-columns: 1fr 1fr 1fr; } }

.roomCard {
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-xl); overflow: hidden;
  box-shadow: var(--sh-sm);
  transition: box-shadow var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out);
}
.roomCard:hover { box-shadow: var(--sh-md); transform: translateY(-3px); }
.roomCard__img-wrap {
  position: relative; overflow: hidden;
  aspect-ratio: 4/3;
}
.roomCard__img-wrap img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform var(--dur-3) var(--ease-out);
}
.roomCard:hover .roomCard__img-wrap img { transform: scale(1.04); }
.roomCard__label {
  position: absolute; bottom: 10px; left: 10px;
  background: rgba(11,18,32,.72); color: #fff;
  backdrop-filter: blur(6px);
  border-radius: 999px; padding: 4px 12px;
  font-size: 13px; font-weight: var(--fw-semibold);
}
.roomCard > p { margin: 0; padding: 14px 16px; color: var(--c-muted); font-size: 14px; }

.roomCard--text { padding: 16px; }
.roomCard__icon-list { display: flex; flex-direction: column; gap: 16px; }
.roomCard__icon-item {
  display: flex; gap: 12px; align-items: flex-start;
}
.roomCard__icon-item .i { color: var(--c-accent); flex-shrink: 0; margin-top: 2px; }
.roomCard__icon-item strong { display: block; font-size: 15px; margin-bottom: 2px; }
.roomCard__icon-item p { margin: 0; color: var(--c-muted); font-size: 13px; }
.i { width: 24px; height: 24px; }
.i-lg { width: 28px; height: 28px; }

/* ===== BENEFITS ===== */
.benefits {
  list-style: none; margin: 0; padding: 0;
  display: grid; gap: 12px;
}
.benefit {
  display: flex; gap: 14px; align-items: flex-start;
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-lg); padding: 16px;
  box-shadow: var(--sh-sm);
  transition: box-shadow var(--dur-2) var(--ease-out);
}
.benefit:hover { box-shadow: var(--sh-md); }
.benefit__icon {
  flex-shrink: 0; width: 36px; height: 36px;
  background: var(--c-green-bg); border-radius: 999px;
  display: grid; place-items: center;
  color: var(--c-success);
}
.benefit__icon svg { width: 20px; height: 20px; }
.benefit p { margin: 4px 0 0; color: var(--c-muted); font-size: 14px; }
@media (min-width: 900px) { .benefits { grid-template-columns: repeat(2, 1fr); } }

/* ===== PLACEMENT LAYOUT ===== */
.placementLayout {
  display: grid; gap: 20px;
}
@media (min-width: 900px) {
  .placementLayout { grid-template-columns: 1fr 1fr; align-items: start; gap: 32px; }
}
.placementPhoto {
  margin: 0; border-radius: var(--r-xl); overflow: hidden;
  box-shadow: var(--sh-md);
}
.placementPhoto img { width: 100%; height: auto; display: block; }

.doDontGrid { display: grid; gap: 14px; }
.doCard, .dontCard {
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-xl); padding: 18px;
  box-shadow: var(--sh-sm);
}
.doCard { border-left: 3px solid var(--c-success); }
.dontCard { border-left: 3px solid var(--c-danger); }
.doCard__title {
  color: var(--c-success);
  display: flex; align-items: center; gap: 8px;
}
.dontCard__title {
  color: var(--c-danger);
  display: flex; align-items: center; gap: 8px;
}
.doCard ul, .dontCard ul { margin: 12px 0 0; padding: 0 0 0 18px; color: var(--c-ink); font-size: 15px; }
.doCard li, .dontCard li { margin: 5px 0; line-height: 1.5; }

/* ===== SPECS ===== */
.specs {
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-xl); padding: 8px 16px; margin: 0;
  box-shadow: var(--sh-sm);
}
.specRow {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; padding: 15px 0; border-bottom: 1px solid var(--c-hairline);
}
.specRow:last-child { border-bottom: 0; }
.specRow dt { color: var(--c-muted); font-size: 14px; }
.specRow dd { margin: 0; font-weight: var(--fw-medium); font-size: 15px; text-align: right; }

/* ===== TIMELINE ===== */
.timeline { list-style: none; margin: 0; padding: 0; display: grid; gap: 12px; }
.timeline__step {
  display: flex; gap: 16px; align-items: flex-start;
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-lg); padding: 16px;
  box-shadow: var(--sh-sm);
}
.timeline__bullet {
  flex-shrink: 0; width: 32px; height: 32px; border-radius: 999px;
  background: var(--grad-btn); color: #fff;
  display: grid; place-items: center;
  font-weight: var(--fw-bold); font-size: 14px;
  box-shadow: 0 3px 8px rgba(37,99,235,.3);
}
.timeline p { margin: 4px 0 0; color: var(--c-muted); font-size: 14px; }

/* ===== FAQ ===== */
.faq {
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-xl); padding: 4px 16px;
  box-shadow: var(--sh-sm); overflow: hidden;
}
.faq details { border-bottom: 1px solid var(--c-hairline); }
.faq details:last-child { border-bottom: 0; }
.faq summary {
  list-style: none; cursor: pointer; padding: 17px 0;
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  font-weight: var(--fw-medium); font-size: 16px; color: var(--c-ink);
  transition: color var(--dur-2) var(--ease-out);
}
.faq summary:hover { color: var(--c-accent); }
.faq summary::-webkit-details-marker { display: none; }
.faq .chev {
  width: 14px; height: 14px; flex-shrink: 0;
  border-right: 2px solid var(--c-muted); border-bottom: 2px solid var(--c-muted);
  transform: rotate(45deg);
  transition: transform var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out);
}
.faq details[open] .chev { transform: rotate(-135deg); border-color: var(--c-accent); }
.faq details > div { padding: 0 0 16px; color: var(--c-muted); font-size: 15px; line-height: 1.6; }

/* ===== FORM ===== */
.section--form {
  background: linear-gradient(180deg, var(--c-base) 0%, #EFF6FF 50%, #FFFFFF 100%);
}
.formCard {
  background: var(--c-surface); border: 1px solid var(--c-hairline);
  border-radius: var(--r-2xl); padding: 24px 20px;
  box-shadow: var(--sh-lg); max-width: 600px; margin: 0 auto;
}
.formCard__product-strip {
  display: flex; align-items: center; gap: 12px;
  background: var(--c-surface-2); border: 1px solid var(--c-hairline);
  border-radius: var(--r-lg); padding: 10px 14px;
  margin-bottom: 20px;
}
.formCard__product-strip img {
  width: 48px; height: 48px; object-fit: contain; border-radius: 10px;
  background: #fff; padding: 4px;
}
.formCard__product-strip div { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.formCard__product-strip strong { font-size: 15px; }
.price-inline { font-size: 13px; color: var(--c-accent); font-weight: var(--fw-semibold); }
.formCard__head { margin-bottom: 18px; }
.field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.label { font-size: 13px; font-weight: var(--fw-medium); color: var(--c-ink); }
.input {
  height: 52px; border-radius: 16px; border: 1.5px solid var(--c-hairline);
  background: var(--c-surface); padding: 0 14px;
  font-size: 16px; color: var(--c-ink);
  transition:
    border-color var(--dur-2) var(--ease-out),
    box-shadow var(--dur-2) var(--ease-out);
  font-family: inherit; width: 100%;
}
.input:focus { outline: none; }
.input:focus-visible { border-color: rgba(37,99,235,.55); box-shadow: 0 0 0 4px rgba(147,197,253,.45); }
.input.is-invalid { border-color: rgba(220,38,38,.65); box-shadow: 0 0 0 4px rgba(220,38,38,.15); }
.helper { font-size: 13px; color: var(--c-muted); margin: 0; }
.error {
  font-size: 13px; color: var(--c-danger); margin: 0 0 12px;
  padding: 10px 12px; background: #FEF2F2;
  border: 1px solid #FECACA; border-radius: 12px;
}

.phoneRow { display: flex; gap: 10px; }
.phoneChip {
  height: 52px; display: flex; align-items: center; padding: 0 14px;
  border-radius: 16px; border: 1.5px solid var(--c-hairline);
  background: var(--c-surface-2); color: var(--c-ink);
  font-weight: var(--fw-medium); font-size: 16px; flex-shrink: 0;
}
.phoneInput { flex: 1; }

.formSubmit { width: 100%; }
.formMessages { margin-bottom: 8px; min-height: 0; }
.formMessages .error { margin: 0 0 14px; }
.spinner { width: 18px; height: 18px; animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.shake { animation: shake .35s var(--ease-out); }
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-6px); }
  75% { transform: translateX(6px); }
}

/* Success pane */
.successPane { text-align: center; padding: 28px 8px; }
.successPane__icon { width: 72px; height: 72px; margin: 0 auto 16px; }
.successPane h3 { margin: 8px 0; }
.successPane p { margin: 8px 0 0; }
.successPane__details {
  display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
  margin-top: 16px;
}
.successPane__details span {
  font-size: 13px; color: var(--c-success); font-weight: var(--fw-medium);
  background: var(--c-green-bg); border-radius: 999px; padding: 5px 12px;
}

/* ===== FOOTER ===== */
.footer {
  background: var(--c-surface-2);
  border-top-left-radius: 24px; border-top-right-radius: 24px;
  border-top: 1px solid var(--c-hairline);
  padding: 32px 0 96px; margin-top: 24px;
}
.footer__grid {
  display: grid; gap: 18px; grid-template-columns: 1fr;
  padding-top: 8px; padding-bottom: 8px;
}
.footer h4 { font-size: 14px; margin: 0 0 6px; color: var(--c-ink); }
.footer .disclaimer { padding: 14px 0 0; max-width: 60em; }
@media (min-width: 700px) { .footer__grid { grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 24px; } }
@media (min-width: 900px) { .footer { padding: 48px 0 64px; } }

/* ===== STICKY CTA (mobile) ===== */
.stickyBar {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 8px 16px max(8px, env(safe-area-inset-bottom));
  background: rgba(255,255,255,.96);
  backdrop-filter: saturate(160%) blur(14px);
  -webkit-backdrop-filter: saturate(160%) blur(14px);
  border-top: 1px solid var(--c-hairline);
  box-shadow: 0 -8px 24px rgba(11,18,32,.09);
  z-index: 50;
}
.stickyBar__inner {
  display: flex; align-items: center; gap: 10px;
  max-width: 600px; margin: 0 auto;
}
.stickyBar__img {
  width: 40px; height: 40px; object-fit: contain;
  border-radius: 10px; background: var(--c-surface-2);
  padding: 3px; flex-shrink: 0;
}
.stickyBar__info { flex: 1; display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.stickyBar__name { font-size: 13px; font-weight: var(--fw-semibold); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.stickyBar__price { font-size: 12px; color: var(--c-accent); font-weight: var(--fw-semibold); }
.stickyBar__btn { flex-shrink: 0; height: 44px; padding: 0 16px; border-radius: 14px; font-size: 15px; }
@media (min-width: 900px) { .stickyBar { display: none; } .pagePadBottom { padding-bottom: 0; } }
.pagePadBottom { padding-bottom: 76px; }

/* ===== REVEAL ANIMATION ===== */
.reveal {
  opacity: 0; transform: translateY(16px);
  transition: opacity var(--dur-3) var(--ease-out), transform var(--dur-3) var(--ease-out);
}
.reveal.is-in { opacity: 1; transform: translateY(0); }
@media (prefers-reduced-motion: reduce) {
  .reveal { transition: none; transform: none; opacity: 1; }
  .wave { animation: none; }
  .productCard__img:hover { transform: none; }
}

/* ===== TINY SCREEN FIXES ===== */
@media (max-width: 359px) {
  .h1 { font-size: 28px; }
  .price { font-size: 24px; }
  .priceCard { flex-direction: column; align-items: flex-start; gap: 6px; }
  .priceCard__notes { text-align: left; }
}
